# Copy this file to .env and fill in real values:  cp .env.example .env
# .env is gitignored; this template is committed. Read by both the FastAPI
# backend (pydantic-settings) and the Vite frontend (VITE_* vars).

# --- Database ---------------------------------------------------------------
# Docker Postgres is mapped to host port 5433 (5432 is taken by a host
# PostgreSQL on the dev machine). See docker-compose.yml.
DATABASE_URL=postgresql://healtharch:healtharch@localhost:5433/healtharch

# --- OpenAI (AI bubble + site-intelligence features) ------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Mapbox (public token: https://account.mapbox.com/) ---------------------
VITE_MAPBOX_TOKEN=

# --- Google Sign-In (WEB OAuth client id from Google Cloud Console) ---------
# Same value in both vars. Add http://localhost:5173 to the client's
# "Authorized JavaScript origins". Used by the React app (VITE_*) and by the
# backend to pin the token audience.
VITE_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=
